{
	"AllowedHosts": "*",
	"G4": {
		"Uia": {
			"IdentityAttributes": [
				"AutomationId",
				"Name"
			]
		}
	},
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://+:9955"
			}
		}
	},
	"Logging": {
		"LogLevel": {
			"Default": "Error",
			"G4.Api": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	}
}
